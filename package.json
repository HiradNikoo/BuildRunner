{
  "name": "build-runner",
  "version": "1.0.0",
  "private": true,
  "description": "BuildRunner - desktop file command manager",
  "main": "dist/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"pnpm --filter renderer dev\" \"pnpm --filter main dev\" \"pnpm --filter preload dev\" \"pnpm start:electron\"",
    "start:electron": "wait-on dist/main/index.js dist/preload/index.js http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "build": "pnpm lint && pnpm typecheck && pnpm --filter renderer build && pnpm --filter main build && pnpm --filter preload build",
    "make": "electron-builder --config electron-builder.yml",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc -p tsconfig.json",
    "test": "vitest",
    "test:e2e": "pnpm --filter main build && pnpm --filter preload build && pnpm --filter renderer build && cross-env CI=1 playwright test",
    "seed": "ts-node --esm scripts/seed.ts"
  },
  "devDependencies": {
    "@playwright/test": "^1.44.0",
    "@types/node": "^20.11.30",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "prettier": "^3.2.5",
    "rimraf": "^5.0.5",
    "ts-node": "^10.9.2",
    "tsup": "^7.2.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.8",
    "vitest": "^1.5.0",
    "wait-on": "^7.2.0"
  },
  "dependencies": {
    "@ant-design/icons": "^5.2.6",
    "antd": "^5.15.2",
    "better-sqlite3": "^9.4.3",
    "dayjs": "^1.11.10",
    "electron-log": "^5.1.1",
    "electron-store": "^8.1.0",
    "immer": "^10.0.2",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.3",
    "serialize-error": "^11.0.0",
    "zustand": "^4.5.2"
  }
}
